# ── Mode ──────────────────────────────────────────
# true  = use cached datasets, no API calls needed (for recruiters/demo)
# false = live Reddit pulls + local Ollama
DEMO_MODE=true

# ── LLM Provider ──────────────────────────────────
# Options: groq | ollama | openai
LLM_PROVIDER=groq

# Groq (free tier, fast — recommended for demo)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ── Reddit API (only needed if DEMO_MODE=false) ────
# Get credentials at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=consensus-agent/1.0