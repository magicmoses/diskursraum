# ── Mode ──────────────────────────────────────────
DEMO_MODE=true
LLM_PROVIDER=groq

# ── LLM ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database ───────────────────────────────────────
RAILWAY_DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Data APIs (only needed if DEMO_MODE=false) ─────
GNEWS_API_KEY=your_newsapi_key_here

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Bluesky — no key needed for public posts
BLUESKY_HANDLE=your_handle_here

